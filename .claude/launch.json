{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static (npx.cmd serve)",
      "runtimeExecutable": "npx.cmd",
      "runtimeArgs": ["serve", "dist", "-p", "5000", "--no-clipboard"],
      "port": 5000
    },
    {
      "name": "Static (npm.cmd serve)",
      "runtimeExecutable": "npm.cmd",
      "runtimeArgs": ["exec", "--", "serve", "dist", "-p", "5000"],
      "port": 5000
    }
  ]
}
