rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Config: public read
    // availability: anyone can update reservedDates (to block dates on booking)
    // pricing and other config: admin write only
    match /config/availability {
      allow read: if true;
      allow update: if true;
      allow create: if true;
    }
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bookings: anyone can create, admin can read/update all
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update: if true;
    }
  }
}
